*modelGenerator, generator=boxGen, name=gen
nX      =1
nY      =1
nZ      =1
lX      =1
lY      =1
lZ      =1
elType  =C3D8


*material, name=LinearElastic, id=myMaterial
3000000,    0.2

*section, name=section1, material=myMaterial, type=solid
all

*job, name=myJob, domain=3d
*solver, name=theSolver, solver=NISTParallel


*fieldOutput
** for ensight output
>>perNode, elSet=all, name=displacement,  field=displacement, result=U
>>perElement, elSet=all, name=stress, result=stress, quadraturePoint=0:8, f(x)='mean(x, axis=1)'
>>perElement, elSet=all, name=strain, result=strain, quadraturePoint=0:8, f(x)='mean(x, axis=1)'
** for xy-data
>>perNode, name=RF, nSet=gen_right, field=displacement, result=P, f(x)='-sum(x[:,  0])'
>>perNode, name=Uleft, nSet=gen_left, field=displacement, result=U, f(x)='mean(x[:, 0])'

*output, type=monitor, name=RFMon
fieldOutput=RF
fieldOutput=Uleft

*output, type=ensight, name=ensightExport
>>perNode,     fieldOutput=displacement
>>perElement,  fieldOutput=strain
>>perElement,  fieldOutput=stress
>>configuration, overwrite=yes

*constraint, type=directionalspringpenalty, name=x_constraintLeftTop
nSet=gen_left
field=displacement
component=0
penalty=1e2

*step, solver=theSolver
maxInc=1.0, minInc=1e-5, maxNumInc=10000, maxIter=25, stepLength=1
>>dirichlet, name=leftFixed, nSet=gen_bottomLeftFront,  field=displacement, 2=0., 3=0.
>>dirichlet, name=leftRot, nSet=gen_bottomLeftBack,  field=displacement, 2=0.

*step, solver=theSolver
maxInc=1e-1, minInc=1e-6, maxNumInc=100000, maxIter=25, stepLength=1
>>options, category=NISTSolver, extrapolation=linear,
>>dirichlet, name=right, nSet=gen_right,  field=displacement, 1=0.1

*step, solver=theSolver
maxInc=1e-1, minInc=1e-6, maxNumInc=100000, maxIter=25, stepLength=1
>>options, category=NISTSolver, extrapolation=linear,
>>dirichlet, name=right, nSet=gen_right,  field=displacement, 1=-0.15
